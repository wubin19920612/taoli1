APP_NAME=Arbitrage Radar
ENVIRONMENT=production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=sqlite:////data/radar.db
POLL_INTERVAL_SECONDS=8
FUNDING_POLL_INTERVAL_SECONDS=120

# Optional dashboard write protection. Leave empty to disable.
DASHBOARD_PASSWORD=

# Optional Feishu custom bot webhook. Keep secrets out of git.
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=

BACKEND_PORT=8000
FRONTEND_PORT=3000
