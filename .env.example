APP_NAME=Arbitrage Radar
ENVIRONMENT=production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=sqlite:////data/radar.db
POLL_INTERVAL_SECONDS=8
FUNDING_POLL_INTERVAL_SECONDS=120

# Optional dashboard write protection. Leave empty to disable.
DASHBOARD_PASSWORD=

# Optional Feishu custom bot webhook. Keep secrets out of git.
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=

# Optional service restart controls for the dashboard.
# Leave blank to follow ENVIRONMENT automatically; enable only in local/test or a private admin network.
SERVICE_CONTROL_ENABLED=
SERVICE_CONTROL_RESTART_DELAY_SECONDS=1
SERVICE_CONTROL_DOCKER_SOCKET_PATH=/var/run/docker.sock

BACKEND_PORT=8000
FRONTEND_PORT=3000
COMPOSE_PROJECT_NAME=taoli1

# Compact opportunity history for small disks.
# Records only filtered top opportunities every 120s and prunes old rows.
HISTORY_ENABLED=true
HISTORY_SAMPLE_SECONDS=120
HISTORY_RETENTION_DAYS=3
HISTORY_KEEP_TOP_N=100
HISTORY_MIN_OPEN_SPREAD_PCT=0.5
HISTORY_MIN_VOLUME_24H_K=100
HISTORY_VACUUM_INTERVAL_SECONDS=86400
